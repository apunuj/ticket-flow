{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ticket-flow.dev/config.schema.json",
  "title": "Ticket-Flow config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "backend",
    "git",
    "test",
    "tools"
  ],
  "properties": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human name of the project/product."
        },
        "ticketPrefix": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9]*$",
          "description": "Optional ticket identifier prefix, e.g. APU for APU-312. Omit to let the skills read the prefix from each ticket id at runtime."
        }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "linear",
            "jira"
          ],
          "description": "Ticket backend. linear and jira are implemented; github is planned."
        },
        "project": {
          "type": "string",
          "description": "Optional backend project: Linear project name, GitHub owner/repo, or Jira project key. Omit to let the skills resolve your active project at runtime."
        },
        "states": {
          "type": "object",
          "additionalProperties": false,
          "description": "Display names for the lifecycle states this backend uses.",
          "properties": {
            "backlog": {
              "type": "string",
              "minLength": 1,
              "default": "Backlog"
            },
            "inProgress": {
              "type": "string",
              "minLength": 1,
              "default": "In Progress"
            },
            "inReview": {
              "type": "string",
              "minLength": 1,
              "default": "In Review"
            },
            "done": {
              "type": "string",
              "minLength": 1,
              "default": "Done"
            }
          }
        }
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseBranch"
      ],
      "properties": {
        "baseBranch": {
          "type": "string",
          "minLength": 1,
          "description": "Integration branch feature PRs target, e.g. stage or main."
        },
        "branchPattern": {
          "type": "string",
          "default": "{prefix-lower}-{number}-{slug}",
          "description": "Ticket branch name template. Tokens: {prefix-lower} {prefix} {number} {slug}."
        },
        "mergeStrategy": {
          "type": "string",
          "enum": [
            "merge",
            "squash",
            "rebase"
          ],
          "default": "merge"
        }
      }
    },
    "test": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1,
          "description": "Test-gate command run before shipping, e.g. ./dev.sh test."
        }
      }
    },
    "conventions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "description": "Short commit/PR conventions surfaced to the skills."
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conventionChecks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Project-specific checks review-ticket asserts beyond the generic code review."
        }
      }
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "claude",
          "copilot",
          "opencode"
        ]
      },
      "description": "Which tool formats to render."
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dir": {
          "type": "string",
          "default": ".",
          "description": "Repo root the tool files are written under."
        },
        "inlineArtifacts": {
          "type": "boolean",
          "default": true,
          "description": "Render the updated work-artifact sections inline in chat after every receipted artifact write. Set false to suppress the inline echo (ticket/PR persistence is unaffected)."
        }
      }
    },
    "orchestrate": {
      "type": "object",
      "description": "Optional role\u2192model mapping for /orchestrate-ticket. When BOTH models are set, runs use the split without asking; otherwise each run asks the operator to pick a split before any phase work. An explicit per-run instruction always wins, for that run only.",
      "additionalProperties": false,
      "properties": {
        "plannerModel": {
          "type": "string",
          "description": "Model for the Planner role (plans + reviews)."
        },
        "implementerModel": {
          "type": "string",
          "description": "Model for the Implementer role (builds + fixes)."
        }
      }
    }
  }
}
